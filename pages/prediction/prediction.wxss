.container {
    padding: 30rpx;
    padding-bottom: 450rpx; 
}

.card-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 30rpx;
}

.button-group {
    bottom: 0;
    left: 0;
    right: 0;
    padding: 60rpx;
    padding-bottom: calc(30rpx + env(safe-area-inset-bottom));
    border-top: 1rpx solid #f2f3f5;
    display: flex;
    flex-direction: column; 
    gap: 30rpx;
}

.button {
    width: 100%;
    height: 80rpx;
    line-height: 96rpx;
    border-radius: 16rpx;
    font-size: 32rpx;
    font-weight: bold;
    border: none;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: opacity 0.2s;
    margin: 0;
}

.button:active {
    opacity: 0.8;
}

.primary {
    background-color: #f97316;
    color: white;
}

.secondary {
    background-color: #fff;
    color: #f97316;
    border: 1rpx solid #f97316;
    box-sizing: border-box;
}

.icon {
    width: 40rpx;
    height: 40rpx;
    margin-right: 16rpx;
}

.clear-btn {
    background-color: #f2f3f5;
    color: #86909c;
    font-weight: normal;
    order: 3; 
}

.secondary { order: 1; }
.primary   { order: 2; }