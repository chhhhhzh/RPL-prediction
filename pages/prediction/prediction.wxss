.container {
    padding: 30rpx;
    padding-bottom: 450rpx; 
    background: linear-gradient(180deg, #fff7ed 0%, #ffffff 80%);
}

.card-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 30rpx;
}

.button-group {
    bottom: 0;
    left: 0;
    right: 0;
    padding: 60rpx;
    padding-bottom: calc(30rpx + env(safe-area-inset-bottom));
    border-top: 1rpx solid #ffedd5;
    background: rgba(255, 255, 255, 0.92);
    display: flex;
    flex-direction: column; 
    gap: 30rpx;
}

.button {
    width: 100%;
    height: 80rpx;
    line-height: 96rpx;
    border-radius: 20rpx;
    font-size: 32rpx;
    font-weight: bold;
    border: none;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: opacity 0.2s;
    margin: 0;
}

.button:active {
    opacity: 0.8;
}

.primary {
    background: linear-gradient(135deg, #fb923c, #f97316);
    color: white;
    box-shadow: 0 14rpx 24rpx rgba(249, 115, 22, 0.24);
}

.secondary {
    background-color: #fff;
    color: #f97316;
    border: 1rpx solid #f97316;
    box-sizing: border-box;
}

.ai {
    background: #fff7ed;
    color: #c2410c;
    border: 1rpx dashed #fdba74;
}

.icon {
    width: 40rpx;
    height: 40rpx;
    margin-right: 16rpx;
}

.clear-btn {
    background-color: #f2f3f5;
    color: #86909c;
    font-weight: normal;
    order: 3; 
}

.ai        { order: 1; }
.secondary { order: 2; }
.primary   { order: 3; }