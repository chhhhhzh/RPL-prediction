.container {
    padding: 30rpx;
  }
  
  .chart-card {
    background-color: #fff;
    padding: 30rpx;
    border-radius: 16rpx;
    margin-bottom: 30rpx;
    box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
  }
  
  .loading-tip {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 40rpx 0;
    background-color: #fff; /* 背景色可根据需求调整 */
  }

  .loading-tip text {
    font-size: 28rpx;
    color: #999;
  }
  
  .chart-title {
    font-size: 36rpx;
    font-weight: bold;
    color: #333;
  }
  
  .chart-container {
    width: 100%;
    height: 500rpx;
    margin-top: 20rpx;
  }
  
  ec-canvas {
    width: 100%;
    height: 100%;
  }
  
  .user-info-card {
    display: flex;
    align-items: center;
    padding: 40rpx;
    background-color: #fff;
    border-radius: 16rpx;
    margin-bottom: 30rpx;
    box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
  }
  
  .user-info-card > .avatar { 
    width: 128rpx;
    height: 128rpx;
    object-fit: cover;
    border-radius: 8rpx;
  }
  
  .nickname {
    font-size: 40rpx;
    font-weight: bold;
    color: #333;
    margin-left: 30rpx;
  }
  
  .card-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 10rpx;
  }
  
  .picker-display {
    display: flex;
    align-items: center;
    background-color: #f7f7f7;
    padding: 10rpx 20rpx;
    border-radius: 10rpx;
  }
  
  .picker-text {
    font-size: 28rpx;
    color: #333;
    margin-right: 10rpx;
  }
  
  .picker-arrow {
    width: 32rpx;
    height: 32rpx;
  }
  
  .auth-container {
    padding: 80rpx 60rpx;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  
  .auth-header {
    text-align: center;
    margin-bottom: 60rpx;
  }
  
  .auth-title {
    font-size: 48rpx;
    font-weight: bold;
    display: block;
  }
  
  .auth-subtitle {
    font-size: 28rpx;
    color: #888;
    margin-top: 20rpx;
    display: block;
    max-width: 80%;
    margin-left: auto;
    margin-right: auto;
  }
  
  .avatar-button {
    width: 128rpx !important;          /* 折中尺寸：80rpx ≈ 40px（iPhone6） */
    height: 128rpx !important;         /* 显式定义高度 */
    min-width: 0 !important;          /* 覆盖按钮默认最小宽度 */
    min-height: 0 !important;         /* 覆盖按钮默认最小高度 */
    padding: 0 !important;            /* 清除内边距 */
    border: 1.5rpx solid #eee;        /* 细边框 */
    border-radius: 8rpx;               /* 适当圆角 */
    display: flex;
    overflow: hidden;
    box-sizing: border-box;
  }
  
  .avatar-button .avatar {
    width: 100% !important;           /* 继承容器宽度 */
    height: 100% !important;           /* 继承容器高度 */
    object-fit: cover;                /* 关键：裁剪填充 */
    border-radius: 8rpx;              /* 与按钮圆角一致 */
  }
  
  .avatar-tip {
    font-size: 24rpx;
    color: #aaa;
    margin-bottom: 60rpx;
  }
  
  .nickname-wrapper {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 30rpx;
    border-radius: 16rpx;
    background-color: #fff;
    font-size: 32rpx;
  }
  
  .nickname-label {
    color: #333;
  }
  
  .nickname-input {
    text-align: right;
  }
  
  .auth-button {
    width: 100%;
    height: 96rpx;
    border-radius: 48rpx;
    background-color: #f97316;
    color: white;
    font-size: 32rpx;
    font-weight: bold;
    margin-top: 80rpx;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .history-item {
    padding: 20rpx;
    border-bottom: 1rpx solid #f0f0f0;
    margin-bottom: 15rpx;
  }
  
  .history-header {
    display: flex;
    justify-content: space-between;
    margin-bottom: 10rpx;
  }
  
  .history-date {
    font-size: 24rpx;
    color: #888;
  }
  
  .history-module {
    font-size: 28rpx;
    font-weight: bold;
    color: #333;
  }
  
  .history-indicators {
    display: flex;
    flex-wrap: wrap;
    margin-bottom: 10rpx;
  }
  
  .indicator-item {
    background: #f8f8f8;
    border-radius: 8rpx;
    padding: 8rpx 15rpx;
    margin-right: 15rpx;
    margin-bottom: 10rpx;
    font-size: 26rpx;
  }
  
  .indicator-label {
    color: #666;
  }
  
  .indicator-value {
    color: #1890ff;
    font-weight: 500;
  }
  
  .history-result {
    text-align: right;
    font-size: 28rpx;
  }
  
  .high-risk {
    color: #f5222d;
    font-weight: bold;
  }
  
  .low-risk {
    color: #52c41a;
    font-weight: bold;
  }
  
  .empty-tip {
    text-align: center;
    padding: 40rpx 0;
    color: #999;
  }
  
  .empty-icon {
    width: 120rpx;
    height: 120rpx;
    display: block;
    margin: 0 auto 20rpx;
  }