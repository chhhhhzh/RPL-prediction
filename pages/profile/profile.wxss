.container {
    padding: 30rpx;
  }
  
  .chart-card {
    background-color: #fff;
    padding: 30rpx;
    border-radius: 16rpx;
    margin-bottom: 30rpx;
    box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
  }
  
  .chart-title {
    font-size: 36rpx;
    font-weight: bold;
    color: #333;
  }
  
  .chart-container {
    width: 100%;
    height: 500rpx;
    margin-top: 20rpx;
  }
  
  ec-canvas {
    width: 100%;
    height: 100%;
  }
  
  .user-info-card {
    display: flex;
    align-items: center;
    padding: 40rpx;
    background-color: #fff;
    border-radius: 16rpx;
    margin-bottom: 30rpx;
    box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
  }
  
  .avatar {
    width: 120rpx;
    height: 120rpx;
    border-radius: 50%;
  }
  
  .nickname {
    font-size: 40rpx;
    font-weight: bold;
    color: #333;
    margin-left: 30rpx;
  }
  
  .card-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 10rpx;
  }
  
  .picker-display {
    display: flex;
    align-items: center;
    background-color: #f7f7f7;
    padding: 10rpx 20rpx;
    border-radius: 10rpx;
  }
  
  .picker-text {
    font-size: 28rpx;
    color: #333;
    margin-right: 10rpx;
  }
  
  .picker-arrow {
    width: 32rpx;
    height: 32rpx;
  }
  
  .auth-container {
    padding: 80rpx 60rpx;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  
  .auth-header {
    text-align: center;
    margin-bottom: 60rpx;
  }
  
  .auth-title {
    font-size: 48rpx;
    font-weight: bold;
    display: block;
  }
  
  .auth-subtitle {
    font-size: 28rpx;
    color: #888;
    margin-top: 20rpx;
    display: block;
    max-width: 80%;
    margin-left: auto;
    margin-right: auto;
  }
  
  .avatar-button {
    width: 180rpx;
    height: 180rpx;
    padding: 0;
    border-radius: 50%;
    border: 4rpx solid #eee;
    margin-bottom: 20rpx;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    box-sizing: border-box;
  }
  
  .avatar-button .avatar {
      width: 100%;
      height: 100%;
  }
  
  .avatar-tip {
    font-size: 24rpx;
    color: #aaa;
    margin-bottom: 60rpx;
  }
  
  .nickname-wrapper {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 30rpx;
    border-radius: 16rpx;
    background-color: #fff;
    font-size: 32rpx;
  }
  
  .nickname-label {
    color: #333;
  }
  
  .nickname-input {
    text-align: right;
  }
  
  .auth-button {
    width: 100%;
    height: 96rpx;
    border-radius: 48rpx;
    background-color: #f97316;
    color: white;
    font-size: 32rpx;
    font-weight: bold;
    margin-top: 80rpx;
    display: flex;
    align-items: center;
    justify-content: center;
  }