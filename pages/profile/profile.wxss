.container {
    padding: 30rpx;
  }
  
  .chart-card {
    background-color: #fff;
    padding: 30rpx;
    border-radius: 16rpx;
    margin-bottom: 30rpx;
    box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
  }
  
  .chart-title {
    font-size: 36rpx;
    font-weight: bold;
    color: #333;
  }
  
  .chart-container {
    width: 100%;
    height: 500rpx;
    margin-top: 20rpx;
  }
  
  ec-canvas {
    width: 100%;
    height: 100%;
  }
  
  .card-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 10rpx;
  }
  
  .picker-display {
    display: flex;
    align-items: center;
    background-color: #f7f7f7;
    padding: 10rpx 20rpx;
    border-radius: 10rpx;
  }
  
  .picker-text {
    font-size: 28rpx;
    color: #333;
    margin-right: 10rpx;
  }
  
  .picker-arrow {
    width: 32rpx;
    height: 32rpx;
  }