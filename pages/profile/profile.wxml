<view>
    <nav-bar title="个人中心" showBack="{{true}}" showHome="{{true}}"></nav-bar>

    <view wx:if="{{isAuthorized}}" class="container">

        <view class="user-info-card">
            <image class="avatar" src="{{userInfo.avatarUrl}}"></image>
            <text class="nickname">{{userInfo.nickName}}</text>
        </view>

        <view class="ai-entry-card" bindtap="goToAIChat">
            <view class="ai-entry-left">
                <text class="ai-entry-title">AI 智能助手</text>
                <text class="ai-entry-desc">结合你的历史趋势与风险因子，给出个性化随访建议</text>
            </view>
            <text class="ai-entry-arrow">›</text>
        </view>

        <view class="chart-card history-card">
            <view class="card-header">
                <text class="chart-title">历史预测记录</text>
                <text wx:if="{{!isHistoryEmpty && !historyLoading}}" class="clear-history-btn" bindtap="handleClearHistory">清空记录</text>
            </view>

            <view wx:if="{{historyLoading}}" class="loading-tip">
                <view class="loading-spinner"></view>
                <text>加载中...</text>
            </view>

            <block wx:else>
                <view wx:if="{{isHistoryEmpty}}" class="empty-tip">
                    <text>暂无历史记录</text>
                </view>

                <scroll-view wx:else scroll-y class="history-scroll">
                    <view wx:for="{{historyList}}" wx:key="_id" class="history-item" bindtap="goToHistoryDetail" data-index="{{index}}">
                        <view class="history-item-left">
                            <text class="history-date">{{item.formattedDate}}</text>
                            <text class="history-time">{{item.formattedTime}}</text>
                        </view>
                        <view class="history-item-right">
                            <view class="probability-badge" style="background-color: {{item.badgeBgColor}}; color: {{item.badgeColor}};">
                                活产率: {{item.liveBirthDisplay}}
                            </view>
                            <view class="arrow-right">›</view>
                        </view>
                    </view>
                </scroll-view>
            </block>
        </view>

        <view class="chart-card">
            <text class="chart-title">六维状态雷达图</text>
            <view class="chart-container">
                <ec-canvas id="radar-chart" canvas-id="radar-canvas" ec="{{ radar }}"></ec-canvas>
            </view>
        </view>

        <view class="chart-card">
            <view class="card-header">
                <text class="chart-title">关键指标历史曲线</text>
                <picker wx:if="{{indicatorList.length}}" bindchange="bindPickerChange" value="{{indicatorIndex}}" range="{{indicatorList}}" range-key="title">
                    <view class="picker-display">
                        <text class="picker-text">{{indicatorList[indicatorIndex].title}}</text>
                        <image class="picker-arrow" src="{{iconDown}}"></image>
                    </view>
                </picker>
                <view wx:else class="picker-display">
                    <text class="picker-text">暂无可用指标</text>
                </view>
            </view>
            <view class="chart-container">
                <ec-canvas id="line-chart" canvas-id="line-canvas" ec="{{ line }}"></ec-canvas>
            </view>
        </view>

        <view class="chart-card ai-insight-card">
            <view class="card-header">
                <text class="chart-title">AI图表解读</text>
                <text class="refresh-ai-btn" bindtap="onRetryProfileAiInsight">重新解读</text>
            </view>
            <view wx:if="{{profileAiLoading}}" class="loading-tip">
                <view class="loading-spinner"></view>
                <text>正在结合雷达图与历史曲线分析...</text>
            </view>
            <view wx:elif="{{profileAiError}}" class="ai-error-tip">
                <text>{{profileAiError}}</text>
            </view>
            <view wx:else class="ai-insight-content">
                <text selectable>{{profileAiText}}</text>
            </view>
        </view>

    </view>

    <view wx:else class="auth-container">
        <view class="auth-header">
            <text class="auth-title">授权以继续</text>
            <text class="auth-subtitle">授权您的头像和昵称，以开启个性化的健康数据管理</text>
        </view>

        <button class="avatar-button" open-type="chooseAvatar" bind:chooseavatar="onChooseAvatar">
            <image class="avatar" src="{{tempAvatarUrl}}"></image>
        </button>
        <text class="avatar-tip">点击授权头像</text>

        <view class="nickname-wrapper">
            <text class="nickname-label">昵称</text>
            <input class="nickname-input" type="nickname" placeholder="请授权或输入昵称" bind:input="onNicknameInput" />
        </view>

        <button class="auth-button" bindtap="handleAuthorize">授权并查看</button>
    </view>

</view>