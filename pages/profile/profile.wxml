<view>
  <nav-bar title="个人中心" showBack="{{true}}" showHome="{{true}}"></nav-bar>

  <view wx:if="{{isAuthorized}}" class="container">
    
    <view class="user-info-card">
      <image class="avatar" src="{{userInfo.avatarUrl}}"></image>
      <text class="nickname">{{userInfo.nickName}}</text>
    </view>

    <view class="chart-card">
      <text class="chart-title">六维状态雷达图</text>
      <view class="chart-container">
        <ec-canvas id="radar-chart" canvas-id="radar-canvas" ec="{{ radar }}"></ec-canvas>
      </view>
    </view>

    <view class="chart-card">
      <view class="card-header">
        <text class="chart-title">关键指标历史曲线</text>
        <picker bindchange="bindPickerChange" value="{{indicatorIndex}}" range="{{indicatorList}}" range-key="title">
          <view class="picker-display">
            <text class="picker-text">{{indicatorList[indicatorIndex].title}}</text>
            <image class="picker-arrow" src="{{iconDown}}"></image>
          </view>
        </picker>
      </view>
      <view class="chart-container">
        <ec-canvas id="line-chart" canvas-id="line-canvas" ec="{{ line }}"></ec-canvas>
      </view>
    </view>
  </view>

  <view wx:else class="auth-container">
    <view class="auth-header">
      <text class="auth-title">授权以继续</text>
      <text class="auth-subtitle">授权您的头像和昵称，以开启个性化的健康数据管理</text>
    </view>

    <button class="avatar-button" open-type="chooseAvatar" bind:chooseavatar="onChooseAvatar">
      <image class="avatar" src="{{tempAvatarUrl}}"></image>
    </button>
    <text class="avatar-tip">点击授权头像</text>

    <view class="nickname-wrapper">
      <text class="nickname-label">昵称</text>
      <input class="nickname-input" type="nickname" placeholder="请授权或输入昵称" bind:input="onNicknameInput"/>
    </view>
    
    <button class="auth-button" bindtap="handleAuthorize">授权并查看</button>
  </view>

</view>