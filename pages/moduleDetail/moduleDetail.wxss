.page-wrapper {
    display: flex;
    flex-direction: column; 
    height: 100vh; 
  }
  
  .container {
    padding: 30rpx;
    flex: 1;
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }
  
  .form-container {
    background-color: #fff;
    border-radius: 16rpx;
    padding: 10rpx 30rpx;
    flex: 1; 
    overflow-y: auto;
  }
  
  .form-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 30rpx 0;
    border-bottom: 1rpx solid #f0f0f0;
  }
  
  .form-item:last-child {
    border-bottom: none;
  }
  
  .form-label {
    font-size: 32rpx;
    color: #333;
  }

 /* 合并样式 */
.picker-display {
    font-size: 14px;
    padding: 10rpx;
    border-radius: 4rpx;
    width: 100%;
    text-align: center;
    /* 默认有值时的样式 */
    color: #333; 
  }
  /* 未选中的样式 */
  .picker-display.placeholder {
    color: grey !important; /* 提高优先级 */
  }

  .form-input {
    text-align: right;
    font-size: 32rpx;
  }
  
  .button.primary {
    background-color: #f97316;
    color: white;
    width: 100%;
    height: 96rpx;
    border-radius: 16rpx;
    font-size: 32rpx;
    font-weight: bold;
    margin-top: 40rpx;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }