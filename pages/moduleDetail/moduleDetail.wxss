.page-wrapper {
    display: flex;
    flex-direction: column; 
    height: 100vh; 
  }
  
  .container {
    padding: 30rpx;
    flex: 1;
    display: flex;
    flex-direction: column;
    overflow: hidden;
  background: linear-gradient(180deg, #fff7ed 0%, #ffffff 85%);
  }

.ai-tip-card {
  background: #fff7ed;
  border: 1rpx solid #fed7aa;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 18rpx;
}

.ai-tip-title {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: #c2410c;
}

.ai-tip-text {
  display: block;
  margin-top: 6rpx;
  font-size: 24rpx;
  color: #9a3412;
  line-height: 1.5;
}
  
  .form-container {
    background-color: #fff;
  border-radius: 20rpx;
    padding: 10rpx 30rpx;
    flex: 1; 
    overflow-y: auto;
  }
  
  .form-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 30rpx 0;
    border-bottom: 1rpx solid #f0f0f0;
  }
  
  .form-item:last-child {
    border-bottom: none;
  }
  
  .form-label {
    font-size: 32rpx;
    color: #333;
    flex-shrink: 0;
    margin-right: 20rpx;
  }
  
  .select-wrapper {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: flex-end;
  }
  
  .picker-display {
    font-size: 32rpx;
    padding: 10rpx;
    border-radius: 4rpx;
    width: 100%;
    text-align: right;
    color: #333; 
  }
  
  .picker-display.placeholder {
    color: #bbbbbb !important; 
  }
  
  .clear-icon {
    padding: 10rpx;
    margin-left: 10rpx;
  }
  
  .form-input {
    text-align: right;
    font-size: 32rpx;
    flex: 1;
  }
  
  .button.primary {
  background: linear-gradient(135deg, #fb923c, #f97316);
    color: white;
    width: 100%;
    height: 96rpx;
  border-radius: 20rpx;
    font-size: 32rpx;
    font-weight: bold;
    margin-top: 40rpx;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  box-shadow: 0 14rpx 24rpx rgba(249, 115, 22, 0.22);
  }