<view class="page-wrapper">
  <nav-bar title="{{module.title}}" showBack="{{true}}" showHome="{{true}}"></nav-bar>
  
  <view class="container">
    <view class="ai-tip-card" bindtap="goToAIChat">
      <text class="ai-tip-title">AI辅助录入</text>
      <text class="ai-tip-text">对这个模块不确定怎么填？点我获取逐项解释与填写建议</text>
    </view>
    <view class="form-container">
      <block wx:for="{{module.indicators}}" wx:key="id">
        <view class="form-item">
          <text class="form-label">{{item.label}}</text>
          
          <view wx:if="{{item.inputType === 'select'}}" class="select-wrapper">
            <picker 
              mode="selector" 
              range="{{item.option}}"
              value="{{item.selectedIndex !== null ? item.selectedIndex : 0}}"
              bindchange="handleSelectChange"
              data-indicatorid="{{item.id}}"
              >
              <view class="picker-display {{item.selectedIndex === null ? 'placeholder' : ''}}">
                  {{item.selectedIndex !== null ? item.option[item.selectedIndex] : item.placeholder}}
              </view>
            </picker>
            <icon 
              wx:if="{{item.selectedIndex !== null}}" 
              class="clear-icon" 
              type="clear" 
              size="18" 
              color="#c9cdd4"
              catchtap="clearSelectValue"
              data-indicatorid="{{item.id}}"
            ></icon>
          </view>

          <input wx:else class="form-input" 
                 type="text" 
                 placeholder="{{item.placeholder}}" 
                 value="{{item.value}}"
                 bindinput="handleInputChange"
                 data-indicatorid="{{item.id}}" />
        </view>
      </block>
    </view>
    <button class="button primary" bindtap="saveAndBack">保存并返回</button>
  </view>
</view>