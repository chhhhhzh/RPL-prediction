page {
    background-color: #fff7ed;
}

.page-container {
    padding: 0;
}

/* 内容区容器 */
.content-area {
    /* 关键：设置一个足够的上边距，避免内容被导航栏遮挡 */
    padding-top: 180rpx;
    /* 左右和下方的内边距 */
    padding-left: 30rpx;
    padding-right: 30rpx;
    padding-bottom: 30rpx;
}

/* 返回按钮样式 */
.back-btn {
    width: 100%;
    height: 90rpx;
    line-height: 65rpx;
    margin-top: 40rpx;
    background-color: #fad7a2;
    color: #214386;
    font-size: 32rpx;
    font-weight: 900;
    border-radius: 20rpx;
    box-shadow: 0 8rpx 32rpx -8rpx rgba(29, 33, 41, 0.08);
}

/* 按钮按下的效果 */
.back-btn:active {
    background-color: #f7f8fa;
}

.card {
    background-color: #fff;
    border-radius: 24rpx;
    padding: 40rpx;
    margin-bottom: 30rpx;
    box-shadow: 0 8rpx 32rpx -8rpx rgba(29, 33, 41, 0.08);
}

.header {
    padding-bottom: 20rpx;
    border-bottom: 1rpx solid #f2f3f5;
    margin-bottom: 30rpx;
}

.date {
    font-size: 32rpx;
    font-weight: 500;
    color: #1d2129;
}

.result-summary {
    display: flex;
    justify-content: space-around;
    text-align: center;
}

.result-item {
    display: flex;
    flex-direction: column;
}

.result-label {
    font-size: 26rpx;
    color: #86909c;
    margin-bottom: 10rpx;
}

.result-value {
    font-size: 40rpx;
    font-weight: 500;
    color: #1d2129;
}

.probability {
    font-size: 52rpx;
    font-weight: 600;
    color: #3491fa;
}

.card-title {
    font-size: 32rpx;
    font-weight: 600;
    color: #1d2129;
    margin-bottom: 30rpx;
    display: block;
}

/* 风险提示 */
.risk-list {
    display: flex;
    flex-direction: column;
    gap: 30rpx;
}

.risk-item {
    border-left: 6rpx solid #ffc107;
    padding-left: 24rpx;
}

.risk-title {
    display: block;
    font-size: 28rpx;
    font-weight: 500;
    color: #1d2129;
}

.risk-tip {
    display: block;
    font-size: 26rpx;
    color: #86909c;
    margin-top: 10rpx;
    line-height: 1.6;
}

/* 输入指标 */
.input-list {
    display: flex;
    flex-direction: column;
    gap: 25rpx;
}

.input-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.input-label {
    font-size: 28rpx;
    color: #4e5969;
}

.input-value {
    font-size: 28rpx;
    font-weight: 500;
    color: #1d2129;
    background-color: #f2f3f5;
    padding: 6rpx 16rpx;
    border-radius: 8rpx;
}