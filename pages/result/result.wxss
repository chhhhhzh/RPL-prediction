page {
    background-color: #fff7ed;
    font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', 'PingFang SC', 'Microsoft YaHei', sans-serif;
  }
  
  .container {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 100vh;
    padding: 40rpx;
    box-sizing: border-box;
    opacity: 0;
    animation: fadeIn 0.5s ease-in-out forwards;
  }
  
  @keyframes fadeIn {
    to {
      opacity: 1;
    }
  }
  
  /* --- 加载与错误状态 --- */
  .loading-container,
  .error-container {
    text-align: center;
    padding: 60rpx;
  }
  
  /* Vant Loading 兼容样式 */
  .loading-container .van-loading__text {
    font-size: 28rpx;
    color: #86909c;
  }
  
  .error-title {
    font-size: 40rpx;
    font-weight: 500;
    color: #e53e3e;
    margin-bottom: 20rpx;
  }
  
  .error-message {
    font-size: 28rpx;
    color: #86909c;
    margin-bottom: 60rpx;
  }
  
  .retry-button {
    background-color: #2672ff;
    color: #fff;
    border-radius: 40rpx;
    height: 80rpx;
    line-height: 80rpx;
    font-size: 30rpx;
    margin-bottom: 30rpx;
  }
  
  .back-button {
    color: #86909c;
    font-size: 28rpx;
  }
  
  /* --- 成功状态 --- */
  .result-container {
    width: 100%;
  }
  
  .result-card {
    background: #ffffff;
    border-radius: 32rpx; /* 更大的圆角 */
    box-shadow: 0 10rpx 40rpx -15rpx rgba(4, 28, 64, 0.1); /* 更柔和的阴影 */
    padding: 60rpx 50rpx;
    margin-bottom: 40rpx;
  }
  
  .probability-section {
    text-align: center;
    border-bottom: 1rpx solid #f2f3f5;
    padding-bottom: 40rpx;
    margin-bottom: 40rpx;
  }
  
  .probability-label {
    font-size: 28rpx;
    color: #86909c; /* 标签颜色 */
    text-transform: uppercase;
    letter-spacing: 2rpx;
  }
  
  .probability-value {
    display: flex;
    justify-content: center;
    align-items: baseline;
    margin-top: 10rpx;
    color: #1d2129; /* 主色 */
  }
  
  .probability-value .value {
    font-size: 120rpx;
    font-weight: 600;
    line-height: 1.2;
  }
  
  .probability-value .percent {
    font-size: 40rpx;
    font-weight: 500;
    margin-left: 8rpx;
  }
  
  .ci-section {
    text-align: center;
  }
  
  .ci-label {
    font-size: 26rpx;
    color: #86909c;
  }
  
  .ci-value {
    display: block;
    font-size: 40rpx;
    font-weight: 500;
    color: #1d2129;
    margin-top: 16rpx;
    letter-spacing: 1rpx;
  }
  
  .info-section {
    background-color: #ffffff;
    border-radius: 24rpx;
    padding: 30rpx 40rpx;
    margin-bottom: 60rpx;
  }
  
  .info-title {
    font-size: 30rpx;
    font-weight: 500;
    color: #1d2129;
    margin-bottom: 16rpx;
  }
  
  .info-text {
    font-size: 26rpx;
    color: #4e5969;
    line-height: 1.7;
  }
  
  .back-button-bottom {
    display: block;
    width: 100%;
    height: 96rpx;
    line-height: 96rpx;
    text-align: center;
    background-color: #2672ff;
    color: #fff;
    border-radius: 48rpx;
    font-size: 32rpx;
    font-weight: 500;
    box-shadow: 0 8rpx 16rpx -4rpx rgba(38, 114, 255, 0.3);
  }  