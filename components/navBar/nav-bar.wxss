.nav-bar {
    background: linear-gradient(180deg, #ffffff 0%, #fffaf5 100%);
    box-shadow: 0 6rpx 18rpx rgba(15, 23, 42, 0.06);
  }
  .nav-bar-content {
    height: 88rpx; /* 官方建议的高度 */
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }
  .title {
    font-size: 34rpx;
    font-weight: bold;
    color: #9a3412;
  }
  .back-icon {
    position: absolute;
    left: 20rpx;
    top: 50%;
    transform: translateY(-50%);
    padding: 10rpx;
    width: 44rpx;
    height: 44rpx;
  }
  .back-icon image {
    width: 100%;
    height: 100%;
  }
  .right-actions {
    position: absolute;
    right: 20rpx;
    top: 50%;
    transform: translateY(-50%);
    display: flex;
    align-items: center;
    gap: 12rpx;
  }
  .ai-pill {
    min-width: 56rpx;
    height: 44rpx;
    padding: 0 14rpx;
    border-radius: 22rpx;
    background: linear-gradient(135deg, #ffb04d, #ff7a1a);
    color: #fff;
    font-size: 24rpx;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 6rpx 16rpx rgba(249, 115, 22, 0.35);
  }
  .home-icon {
    position: relative;
    padding: 10rpx;
    width: 48rpx;
    height: 48rpx;
  }
  .home-icon image {
    width: 100%;
    height: 100%;
  }