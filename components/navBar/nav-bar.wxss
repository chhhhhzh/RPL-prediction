.nav-bar {
    background-color: #fff;
    box-shadow: 0 2rpx 4rpx rgba(0,0,0,0.05);
  }
  .nav-bar-content {
    height: 88rpx; /* 官方建议的高度 */
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }
  .title {
    font-size: 34rpx;
    font-weight: bold;
  }
  .back-icon {
    position: absolute;
    left: 20rpx;
    top: 50%;
    transform: translateY(-50%);
    padding: 10rpx;
    width: 44rpx;
    height: 44rpx;
  }
  .back-icon image {
    width: 100%;
    height: 100%;
  }
  .home-icon {
    position: absolute;
    right: 20rpx;
    top: 50%;
    transform: translateY(-50%);
    padding: 10rpx;
    width: 48rpx;
    height: 48rpx;
  }
  .home-icon image {
    width: 100%;
    height: 100%;
  }